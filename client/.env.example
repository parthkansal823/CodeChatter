# ===========================
# CLIENT ENVIRONMENT VARIABLES
# ===========================

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_FRONTEND_URL=http://localhost:5173

# Environment
VITE_ENV=development

# Optional: Feature flags
VITE_ENABLE_MOCK_AUTH=false
VITE_LOG_SECURITY_WARNINGS=true
VITE_DEBUG_MODE=false

# ===========================
# IMPORTANT SECURITY NOTES
# ===========================

# 1. NEVER commit actual credentials to git
# 2. Use .env.local for local development (git-ignored)
# 3. Use environment-specific .env files for different environments
# 4. Keep API keys and secrets secure in production
# 5. Use a secrets management tool (AWS Secrets Manager, HashiCorp Vault, etc.)

# ===========================
# Setup Instructions
# ===========================

# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Update values for your environment
#
# 3. Add .env.local to .gitignore (should already be there)
#
# 4. Run: npm run dev

# ===========================
# For Production
# ===========================

# Set via CI/CD environment variables or secrets manager:
# - VITE_API_URL: Your production API URL (HTTPS)
# - All OAuth credentials should be in backend .env only
# - Never expose secrets in frontend code
